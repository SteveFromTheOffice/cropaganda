<Window x:Class="Cropaganda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Cropaganda"
        Title="Cropaganda"
        Height="720" Width="960"
        MinHeight="400" MinWidth="400"
        Background="#1E1E1E"
        AllowDrop="True"
        WindowStyle="SingleBorderWindow"
        Focusable="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Status bar -->
        <Border Grid.Row="0" Background="#2C2C2C">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="FileNameText"
                           Grid.Column="0"
                           Text="Drop photos to begin"
                           Foreground="#BBBBBB"
                           FontFamily="Segoe UI" FontSize="13"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock x:Name="ProgressText"
                           Grid.Column="1"
                           Foreground="#777777"
                           FontFamily="Segoe UI" FontSize="13"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0" />

                <TextBlock Grid.Column="2"
                           Text="Enter=Save  ←→=Navigate  Esc=Quit"
                           Foreground="#444444"
                           FontFamily="Segoe UI" FontSize="11"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0" />
            </Grid>
        </Border>

        <!-- Crop canvas -->
        <local:CropCanvas x:Name="CropCanvas" Grid.Row="1" />

        <!-- Error toast -->
        <Border x:Name="ErrorToast"
                Grid.Row="1"
                VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,16,0,0"
                Background="#CC991111"
                CornerRadius="4"
                Padding="14,8"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText"
                       Foreground="White"
                       FontFamily="Segoe UI" FontSize="13"
                       TextWrapping="Wrap" MaxWidth="500" />
        </Border>

        <!-- Done overlay -->
        <Border x:Name="DoneOverlay"
                Grid.Row="1"
                Background="#CC000000"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="✓"
                           Foreground="#66DD66"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />
                <TextBlock x:Name="DoneText"
                           Foreground="White"
                           FontFamily="Segoe UI" FontSize="20"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="560"
                           Margin="20,0,20,0" />
                <Button x:Name="DoneCloseButton"
                        Content="Start new batch"
                        Width="160" Height="38"
                        Margin="0,24,0,0"
                        FontFamily="Segoe UI" FontSize="14"
                        Background="#444444" Foreground="White"
                        BorderBrush="#666666"
                        Click="DoneCloseButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
